{
  "name": "vinhphat-app-v2",
  "private": true,
  "version": "2.0.0",
  "author": "Vũ Tiến Lực",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "cd server && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc -b && vite build",
    "build:server": "cd server && npm run build",
    "build:all": "npm run build && npm run build:server",
    "lint": "eslint . --ext ts,tsx",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write .",
    "check": "npm run lint && npm run typecheck",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "ai:audit": "node scripts/ai-audit.js",
    "typecheck:server": "cd server && npm run typecheck",
    "server:install": "cd server && npm install",
    "db:push": "npx supabase db push",
    "db:new": "npx supabase migration new",
    "db:status": "npx supabase migration list",
    "db:reload": "node scripts/db-reload-schema.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-query": "^5.59.0",
    "@types/dompurify": "^3.0.5",
    "@types/qrcode": "^1.5.6",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "dompurify": "^3.3.3",
    "dotenv": "^17.4.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.8.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/mocker": "^4.1.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "sql-lint": "^1.0.2",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2",
    "vite": "^8.0.7",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
