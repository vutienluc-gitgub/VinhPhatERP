
echo "🛡️ Level 7 Defense: Pre-commit checks starting..."

# 1. Fix nhanh từng file
echo "⚡ Running lint-staged (Fix & Format)..."
npx lint-staged || exit 1

# 2. Type check toàn project (QUAN TRỌNG)
echo "🔍 Running TypeScript check..."
npx tsc --noEmit || exit 1

# 3. Kiểm tra có diff không
if [ -z "$(git diff --cached)" ]; then
  echo "⚠️ No staged changes"
  exit 0
fi

echo "✅ Pre-commit checks passed."